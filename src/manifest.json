{
  "manifest_version": 2,
  "name": "CoordCloak",
  "version": "1.0.0",
  "description": "Spoof your browser geolocation with custom coordinates",
  "author": "CoordCloak",

  "icons": {
    "48": "../icons/icon48.png",
    "96": "../icons/icon96.png"
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "../icons/icon48.png"
    },
    "default_title": "CoordCloak"
  },

  "permissions": [
    "storage",
    "tabs",
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "coordcloak@extension",
      "strict_min_version": "63.0"
    }
  }
}